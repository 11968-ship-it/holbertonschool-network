#!/usr/bin/env bash
# Configures /etc/hosts to redirect localhost and facebook.com

# Use cat to read the file, change the text, and overwrite /etc/hosts
# This avoids the "Device or resource busy" error
hosts_content=$(sed 's/127.0.0.1/127.0.0.2/g' /etc/hosts)
echo "$hosts_content" > /etc/hosts

# Add facebook.com if it's not already there
if ! grep -q "facebook.com" /etc/hosts; then
    echo "8.8.8.8 facebook.com" >> /etc/hosts
fi
